{
  "name": "registry-vault",
  "version": "1.0.1",
  "private": false,
  "scripts": {
    "dev": "pnpm --filter @registry-vault/api dev",
    "dev:web": "pnpm --filter @registry-vault/web dev",
    "dev:api": "pnpm --filter @registry-vault/api dev",
    "build": "pnpm --filter @registry-vault/web build && pnpm --filter @registry-vault/api build",
    "build:web": "pnpm --filter @registry-vault/web build",
    "build:api": "pnpm --filter @registry-vault/api build",
    "start": "pnpm --filter @registry-vault/api start:prod",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "better-sqlite3",
      "@nestjs/core",
      "@swc/core",
      "esbuild"
    ]
  }
}
